# Copy this file to .env in each app and fill in the values
# ─── Database ───────────────────────────────────────────────
DATABASE_URL="postgresql://admin:root@localhost:5432/cement_house"

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── API ────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-random-32-char-string"
JWT_EXPIRES_IN="7d"
PORT=4000

# ─── Web App ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ─── WhatsApp (Meta Cloud API) ──────────────────────────────
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
WHATSAPP_ACCESS_TOKEN="your-access-token"
WHATSAPP_VERIFY_TOKEN="your-webhook-verify-token"

# ─── File Storage (Backblaze B2) ────────────────────────────
B2_KEY_ID="your-b2-key-id"
B2_APP_KEY="your-b2-app-key"
B2_BUCKET_NAME="cement-house-uploads"
