# Copy this file to .env in each app and fill in the values
# ─── Database ───────────────────────────────────────────────
DATABASE_URL="postgresql://admin:root@localhost:5432/cement_house"

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── API ────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-random-32-char-string"
JWT_EXPIRES_IN="7d"
PORT=4000
SUPER_ADMIN_SETUP_KEY="set-a-long-random-bootstrap-key"
RAZORPAY_KEY_ID="rzp_test_your_account_key_id"
RAZORPAY_KEY_SECRET="your_account_key_secret"



# ─── Web App ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ─── WhatsApp (Meta Cloud API) ──────────────────────────────
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
WHATSAPP_ACCESS_TOKEN="your-access-token"
WHATSAPP_VERIFY_TOKEN="your-webhook-verify-token"

# ─── File Storage (Backblaze B2) ────────────────────────────
B2_KEY_ID="your-b2-key-id"
B2_APP_KEY="your-b2-app-key"
B2_BUCKET_NAME="cement-house-uploads"



# SMTP email (password reset)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM_EMAIL="your-email@gmail.com"
WEB_URL="http://localhost:3000"
