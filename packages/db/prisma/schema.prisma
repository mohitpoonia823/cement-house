// ============================================================
// Cement House — Multi-Tenant Construction Distributor App
// Prisma Schema (PostgreSQL)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  OWNER
  MUNIM
}

enum SubscriptionPlan {
  STARTER
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  SUSPENDED
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum RiskTag {
  RELIABLE
  WATCH
  BLOCKED
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  DISPATCHED
  DELIVERED
  CANCELLED
}

enum PaymentMode {
  CASH
  UPI
  CHEQUE
  CREDIT      // full udhar
  PARTIAL     // partial payment, rest udhar
}

enum LedgerEntryType {
  DEBIT       // sale made → customer owes money
  CREDIT      // payment received → reduces balance
}

enum DeliveryStatus {
  SCHEDULED
  IN_TRANSIT
  DELIVERED
  FAILED
}

enum ConfirmationType {
  OTP
  PHOTO
  MANUAL
}

enum StockMovementType {
  IN          // purchase from supplier
  OUT         // sale/delivery to customer
  ADJUSTMENT  // manual correction
}

enum ReminderChannel {
  WHATSAPP
  SMS
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum PaymentProvider {
  DUMMY
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum SalesReturnStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum OrderReturnStatus {
  NONE
  PARTIAL
  FULL
}

enum LocationType {
  STORE
  GODOWN
  WAREHOUSE
  YARD
}

enum StockTransferStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

// ─────────────────────────────────────────
// BUSINESS — each cement house / tenant
// ─────────────────────────────────────────

model Business {
  id          String   @id @default(uuid())
  name        String   // e.g. "Shree Cement House", "Sharma Cement Store"
  city        String   // e.g. "Hisar", "Rohtak"
  address     String?
  phone       String?
  gstin       String?
  stateCode   String?
  businessType String  @default("GENERAL_STORE")
  customLabels Json?
  enabledModules Json? @default("[]")
  featureFlags Json? @default("{}")
  defaultSettings Json? @default("{}")
  isActive    Boolean  @default(true)
  remindersEnabled Boolean @default(true)
  reminderSoftDays Int     @default(7)
  reminderFollowDays Int   @default(15)
  reminderFirmDays Int     @default(30)
  subscriptionPlan SubscriptionPlan   @default(STARTER)
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  subscriptionEndsAt DateTime?
  trialStartedAt DateTime?
  trialDaysOverride Int?
  subscriptionInterval BillingInterval?
  monthlySubscriptionAmount Decimal @default(0) @db.Decimal(10, 2)
  yearlySubscriptionAmount Decimal @default(0) @db.Decimal(10, 2)
  suspendedReason String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users       User[]
  customers   Customer[]
  materials   Material[]
  orders      Order[]
  salesReturns SalesReturn[]
  ledgerEntries LedgerEntry[]
  stockMovements StockMovement[]
  auditLogs   AuditLog[]
  paymentMethods PaymentMethod[]
  paymentTransactions PaymentTransaction[]
  locations   Location[]
  materialStocks MaterialStock[]
  stockTransfers StockTransfer[]

  @@index([isActive, subscriptionStatus])
  @@map("businesses")
}

// ─────────────────────────────────────────
// USERS — owner and munim login accounts
// ─────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  name          String
  phone         String   @unique
  role          UserRole @default(MUNIM)
  permissions   String[] @default([])
  passwordHash  String
  isActive      Boolean  @default(true)
  lastSeenAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Tenant
  business      Business? @relation(fields: [businessId], references: [id])
  businessId    String?

  // Relations
  ordersCreated    Order[]         @relation("OrderCreatedBy")
  salesReturnsCreated SalesReturn[]
  ledgerEntries    LedgerEntry[]   @relation("LedgerRecordedBy")
  stockMovements   StockMovement[] @relation("StockRecordedBy")
  auditLogs        AuditLog[]      @relation("AuditActor")
  stockTransfersCreated StockTransfer[]

  @@index([businessId, role, isActive])
  @@index([lastSeenAt])
  @@map("users")
}

// ─────────────────────────────────────────
// CUSTOMERS — all parties / contractors
// ─────────────────────────────────────────

model Customer {
  id           String   @id @default(uuid())
  name         String
  phone        String
  altPhone     String?
  address      String?
  siteAddress  String?
  gstin        String?
  stateCode    String?
  creditLimit  Decimal  @default(0) @db.Decimal(12, 2)
  riskTag      RiskTag  @default(RELIABLE)
  notes        String?
  isActive     Boolean  @default(true)
  remindersEnabled Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Tenant
  business     Business @relation(fields: [businessId], references: [id])
  businessId   String

  // Relations
  orders         Order[]
  salesReturns   SalesReturn[]
  ledgerEntries  LedgerEntry[]
  reminders      Reminder[]

  @@index([businessId, isActive, name])
  @@index([businessId, riskTag, isActive])
  @@index([phone, businessId])
  @@map("customers")
}

// ─────────────────────────────────────────
// MATERIALS — cement, bajri, saria, crusher
// ─────────────────────────────────────────

model Material {
  id              String   @id @default(uuid())
  name            String   // e.g. "OPC Cement", "Bajri / Sand"
  category        String?
  unit            String   // "bags", "MT", "feet"
  stockQty        Decimal  @default(0) @db.Decimal(12, 3)
  minThreshold    Decimal  @default(0) @db.Decimal(12, 3)
  maxThreshold    Decimal? @db.Decimal(12, 3)
  purchasePrice   Decimal  @db.Decimal(10, 2)  // cost per unit
  salePrice       Decimal  @db.Decimal(10, 2)  // default sale price per unit
  barcode         String?
  batchNumber     String?
  expiryDate      DateTime?
  manufactureDate DateTime?
  manufacturer    String?
  rackLocation    String?
  size            String?
  color           String?
  material        String?
  weight          Decimal? @db.Decimal(12, 3)
  purity          Decimal? @db.Decimal(8, 3)
  makingCharges   Decimal? @db.Decimal(10, 2)
  serialNumber    String?
  imeiNumber      String?
  grossWeight     Decimal? @db.Decimal(12, 3)
  tareWeight      Decimal? @db.Decimal(12, 3)
  netWeight       Decimal? @db.Decimal(12, 3)
  metadata        Json?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Tenant
  business        Business @relation(fields: [businessId], references: [id])
  businessId      String

  // Relations
  orderItems      OrderItem[]
  salesReturnItems SalesReturnItem[]
  stockMovements  StockMovement[]
  deliveryItems   DeliveryItem[]
  locationStocks  MaterialStock[]
  transferItems   StockTransferItem[]

  @@index([businessId, isActive, name])
  @@index([businessId, isActive, stockQty])
  @@map("materials")
}

// ─────────────────────────────────────────
// ORDERS — every sale transaction
// ─────────────────────────────────────────

model Order {
  id            String      @id @default(uuid())
  orderNumber   String      @unique  // ORD-2026-0841
  invoiceNumber String?
  customer      Customer    @relation(fields: [customerId], references: [id])
  customerId    String
  createdBy     User        @relation("OrderCreatedBy", fields: [createdById], references: [id])
  createdById   String
  orderDate     DateTime    @default(now())
  deliveryDate  DateTime?
  status        OrderStatus @default(CONFIRMED)
  paymentMode   PaymentMode
  subtotal          Decimal?    @db.Decimal(12, 2)
  itemDiscountTotal Decimal?    @db.Decimal(12, 2)
  invoiceDiscount   Decimal?    @db.Decimal(12, 2)
  taxableAmount     Decimal?    @db.Decimal(12, 2)
  gstTotal          Decimal?    @db.Decimal(12, 2)
  cgstTotal         Decimal?    @db.Decimal(12, 2)
  sgstTotal         Decimal?    @db.Decimal(12, 2)
  igstTotal         Decimal?    @db.Decimal(12, 2)
  transportCharges  Decimal?    @db.Decimal(12, 2)
  loadingCharges    Decimal?    @db.Decimal(12, 2)
  roundOff          Decimal?    @db.Decimal(10, 2)
  grandTotal        Decimal?    @db.Decimal(12, 2)
  paidAmount        Decimal?    @db.Decimal(12, 2)
  dueAmount         Decimal?    @db.Decimal(12, 2)
  billingSnapshot   Json?
  returnedAmount    Decimal?    @db.Decimal(12, 2)
  returnStatus      OrderReturnStatus @default(NONE)
  amountPaid    Decimal     @default(0) @db.Decimal(12, 2)
  totalAmount   Decimal     @db.Decimal(12, 2)
  marginPct     Decimal?    @db.Decimal(5, 2)  // calculated margin %
  notes         String?
  isDeleted     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Tenant
  business      Business    @relation(fields: [businessId], references: [id])
  businessId    String

  // Relations
  items          OrderItem[]
  deliveries     Delivery[]
  salesReturns   SalesReturn[]
  ledgerEntries  LedgerEntry[]
  stockMovements StockMovement[]
  sourceLocation Location? @relation("OrderSourceLocation", fields: [sourceLocationId], references: [id])
  sourceLocationId String?

  @@index([businessId, isDeleted, createdAt])
  @@index([businessId, status, isDeleted, createdAt])
  @@index([businessId, customerId, isDeleted, createdAt])
  @@index([customerId, createdAt])
  @@index([businessId, sourceLocationId, createdAt])
  @@map("orders")
}

model Location {
  id          String       @id @default(uuid())
  business    Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessId  String
  name        String
  type        LocationType @default(STORE)
  address     String?
  isDefault   Boolean      @default(false)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  orderSources       Order[]          @relation("OrderSourceLocation")
  materialStocks     MaterialStock[]
  fromTransfers      StockTransfer[]  @relation("StockTransferFrom")
  toTransfers        StockTransfer[]  @relation("StockTransferTo")

  @@index([businessId, isActive, name])
  @@index([businessId, isDefault])
  @@map("locations")
}

model MaterialStock {
  id         String    @id @default(uuid())
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessId String
  material   Material  @relation(fields: [materialId], references: [id], onDelete: Cascade)
  materialId String
  location   Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  locationId String
  quantity   Decimal   @default(0) @db.Decimal(12, 3)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([businessId, materialId, locationId])
  @@index([businessId, locationId, materialId])
  @@index([businessId, materialId])
  @@map("material_stock")
}

model StockTransfer {
  id             String              @id @default(uuid())
  business       Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessId     String
  fromLocation   Location            @relation("StockTransferFrom", fields: [fromLocationId], references: [id])
  fromLocationId String
  toLocation     Location            @relation("StockTransferTo", fields: [toLocationId], references: [id])
  toLocationId   String
  status         StockTransferStatus @default(COMPLETED)
  createdBy      User                @relation(fields: [createdById], references: [id])
  createdById    String
  notes          String?
  createdAt      DateTime            @default(now())
  items          StockTransferItem[]

  @@index([businessId, createdAt])
  @@index([businessId, fromLocationId, createdAt])
  @@index([businessId, toLocationId, createdAt])
  @@map("stock_transfers")
}

model StockTransferItem {
  id         String        @id @default(uuid())
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  transferId String
  material   Material      @relation(fields: [materialId], references: [id])
  materialId String
  quantity   Decimal       @db.Decimal(12, 3)

  @@index([transferId])
  @@index([materialId])
  @@map("stock_transfer_items")
}

// ─────────────────────────────────────────
// ORDER ITEMS — line items per order
// ─────────────────────────────────────────

model OrderItem {
  id             String   @id @default(uuid())
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId        String
  material       Material @relation(fields: [materialId], references: [id])
  materialId     String
  quantity       Decimal  @db.Decimal(12, 3)
  hsnCode        String?
  gstRate        Decimal? @db.Decimal(5, 2)
  taxableAmount  Decimal? @db.Decimal(12, 2)
  gstAmount      Decimal? @db.Decimal(12, 2)
  cgstAmount     Decimal? @db.Decimal(12, 2)
  sgstAmount     Decimal? @db.Decimal(12, 2)
  igstAmount     Decimal? @db.Decimal(12, 2)
  discountAmount Decimal? @db.Decimal(12, 2)
  unitPrice      Decimal  @db.Decimal(10, 2)  // actual sale price charged
  purchasePrice  Decimal  @db.Decimal(10, 2)  // cost at time of order (snapshot)
  lineTotal      Decimal  @db.Decimal(12, 2)  // quantity × unitPrice
  returnItems    SalesReturnItem[]

  @@index([orderId])
  @@index([materialId])
  @@map("order_items")
}

model SalesReturn {
  id                     String            @id @default(uuid())
  business               Business          @relation(fields: [businessId], references: [id])
  businessId             String
  order                  Order             @relation(fields: [orderId], references: [id])
  orderId                String
  customer               Customer          @relation(fields: [customerId], references: [id])
  customerId             String
  returnNumber           String
  returnDate             DateTime          @default(now())
  reason                 String?
  totalReturnAmount      Decimal           @db.Decimal(12, 2)
  gstReversalAmount      Decimal           @db.Decimal(12, 2)
  ledgerAdjustmentAmount Decimal           @db.Decimal(12, 2)
  status                 SalesReturnStatus @default(COMPLETED)
  createdBy              User              @relation(fields: [createdById], references: [id])
  createdById            String
  createdAt              DateTime          @default(now())
  items                  SalesReturnItem[]

  @@index([businessId, returnDate, createdAt])
  @@index([businessId, orderId, createdAt])
  @@index([businessId, customerId, createdAt])
  @@unique([businessId, returnNumber])
  @@map("sales_returns")
}

model SalesReturnItem {
  id               String      @id @default(uuid())
  return           SalesReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  returnId         String
  orderItem        OrderItem   @relation(fields: [orderItemId], references: [id])
  orderItemId      String
  material         Material    @relation(fields: [materialId], references: [id])
  materialId       String
  quantityReturned Decimal     @db.Decimal(12, 3)
  unitPrice        Decimal     @db.Decimal(10, 2)
  discountAmount   Decimal     @db.Decimal(12, 2)
  taxableAmount    Decimal     @db.Decimal(12, 2)
  gstAmount        Decimal     @db.Decimal(12, 2)
  totalAmount      Decimal     @db.Decimal(12, 2)
  cgstAmount       Decimal?    @db.Decimal(12, 2)
  sgstAmount       Decimal?    @db.Decimal(12, 2)
  igstAmount       Decimal?    @db.Decimal(12, 2)

  @@index([returnId])
  @@index([orderItemId])
  @@index([materialId])
  @@map("sales_return_items")
}

// ─────────────────────────────────────────
// LEDGER ENTRIES — digital khata
// Every debit (sale) and credit (payment) for each customer
// ─────────────────────────────────────────

model LedgerEntry {
  id           String          @id @default(uuid())
  customer     Customer        @relation(fields: [customerId], references: [id])
  customerId   String
  order        Order?          @relation(fields: [orderId], references: [id])
  orderId      String?
  type         LedgerEntryType // DEBIT or CREDIT
  amount       Decimal         @db.Decimal(12, 2)
  paymentMode  PaymentMode?
  reference    String?         // UPI txn ID, cheque number, etc.
  notes        String?
  recordedBy   User            @relation("LedgerRecordedBy", fields: [recordedById], references: [id])
  recordedById String
  createdAt    DateTime        @default(now())

  // Tenant
  business     Business        @relation(fields: [businessId], references: [id])
  businessId   String

  @@index([businessId, customerId, createdAt])
  @@index([customerId, type])
  @@index([businessId, type, createdAt])
  @@index([orderId])
  @@map("ledger_entries")
}

// ─────────────────────────────────────────
// DELIVERIES — each dispatch trip / challan
// ─────────────────────────────────────────

model Delivery {
  id                String           @id @default(uuid())
  order             Order            @relation(fields: [orderId], references: [id])
  orderId           String
  challanNumber     String           @unique  // CH-2026-0839
  driverName        String?
  vehicleNumber     String?
  status            DeliveryStatus   @default(SCHEDULED)
  confirmationType  ConfirmationType?
  confirmationRef   String?          // OTP code, photo URL, or manual note
  deliveredAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  // Relations
  items  DeliveryItem[]

  @@index([orderId, createdAt])
  @@index([status, createdAt])
  @@map("deliveries")
}

// ─────────────────────────────────────────
// DELIVERY ITEMS — actual qty delivered per material
// Separate from order items to handle disputes
// ─────────────────────────────────────────

model DeliveryItem {
  id           String   @id @default(uuid())
  delivery     Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  deliveryId   String
  material     Material @relation(fields: [materialId], references: [id])
  materialId   String
  orderedQty   Decimal  @db.Decimal(12, 3)
  deliveredQty Decimal  @db.Decimal(12, 3)

  @@index([deliveryId])
  @@index([materialId])
  @@map("delivery_items")
}

// ─────────────────────────────────────────
// STOCK MOVEMENTS — full inventory audit trail
// Auto-created on order, delivery, and manual adjustment
// ─────────────────────────────────────────

model StockMovement {
  id           String            @id @default(uuid())
  material     Material          @relation(fields: [materialId], references: [id])
  materialId   String
  order        Order?            @relation(fields: [orderId], references: [id])
  orderId      String?
  type         StockMovementType // IN, OUT, ADJUSTMENT
  quantity     Decimal           @db.Decimal(12, 3)
  stockAfter   Decimal           @db.Decimal(12, 3)  // snapshot of stock after this move
  reason       String?
  recordedBy   User              @relation("StockRecordedBy", fields: [recordedById], references: [id])
  recordedById String
  createdAt    DateTime          @default(now())

  // Tenant
  business     Business          @relation(fields: [businessId], references: [id])
  businessId   String

  @@index([businessId, materialId, createdAt])
  @@index([materialId, createdAt])
  @@index([orderId])
  @@map("stock_movements")
}

// ─────────────────────────────────────────
// REMINDERS — automated payment follow-ups
// Queued by the background job engine
// ─────────────────────────────────────────

model Reminder {
  id           String          @id @default(uuid())
  customer     Customer        @relation(fields: [customerId], references: [id])
  customerId   String
  channel      ReminderChannel @default(WHATSAPP)
  status       ReminderStatus  @default(PENDING)
  messageBody  String
  scheduledAt  DateTime
  sentAt       DateTime?
  createdAt    DateTime        @default(now())

  @@index([customerId, createdAt])
  @@index([status, createdAt])
  @@index([scheduledAt])
  @@map("reminders")
}

model AuditLog {
  id          String   @id @default(uuid())
  actor       User?    @relation("AuditActor", fields: [actorId], references: [id])
  actorId     String?
  business    Business? @relation(fields: [businessId], references: [id])
  businessId  String?
  action      String
  targetType  String
  targetId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([action, createdAt])
  @@index([businessId, createdAt])
  @@map("audit_logs")
}

model PlatformSetting {
  id                 String   @id
  trialDays          Int      @default(7)
  monthlyPrice       Decimal  @default(200) @db.Decimal(10, 2)
  yearlyPrice        Decimal  @default(2100) @db.Decimal(10, 2)
  currency           String   @default("INR")
  trialRequiresCard  Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("platform_settings")
}

model PaymentMethod {
  id                      String          @id @default(uuid())
  business                Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessId              String
  provider                PaymentProvider @default(DUMMY)
  providerCustomerId      String?
  providerPaymentMethodId String?
  cardholderName          String
  brand                   String
  last4                   String
  expMonth                Int
  expYear                 Int
  isDefault               Boolean         @default(true)
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  transactions PaymentTransaction[]

  @@index([businessId, isDefault])
  @@map("payment_methods")
}

model PaymentTransaction {
  id              String          @id @default(uuid())
  business        Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessId      String
  paymentMethod   PaymentMethod?  @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  paymentMethodId String?
  provider        PaymentProvider @default(DUMMY)
  interval        BillingInterval
  amount          Decimal         @db.Decimal(10, 2)
  currency        String          @default("INR")
  status          PaymentStatus   @default(PENDING)
  reference       String?
  failureReason   String?
  metadata        Json?
  paidAt          DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([businessId, createdAt])
  @@map("payment_transactions")
}
