// ============================================================
// Cement House — Multi-Tenant Construction Distributor App
// Prisma Schema (PostgreSQL)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  OWNER
  MUNIM
}

enum SubscriptionPlan {
  STARTER
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  SUSPENDED
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum RiskTag {
  RELIABLE
  WATCH
  BLOCKED
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  DISPATCHED
  DELIVERED
  CANCELLED
}

enum PaymentMode {
  CASH
  UPI
  CHEQUE
  CREDIT      // full udhar
  PARTIAL     // partial payment, rest udhar
}

enum LedgerEntryType {
  DEBIT       // sale made → customer owes money
  CREDIT      // payment received → reduces balance
}

enum DeliveryStatus {
  SCHEDULED
  IN_TRANSIT
  DELIVERED
  FAILED
}

enum ConfirmationType {
  OTP
  PHOTO
  MANUAL
}

enum StockMovementType {
  IN          // purchase from supplier
  OUT         // sale/delivery to customer
  ADJUSTMENT  // manual correction
}

enum ReminderChannel {
  WHATSAPP
  SMS
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum PaymentProvider {
  DUMMY
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
}

// ─────────────────────────────────────────
// BUSINESS — each cement house / tenant
// ─────────────────────────────────────────

model Business {
  id          String   @id @default(uuid())
  name        String   // e.g. "Shree Cement House", "Sharma Cement Store"
  city        String   // e.g. "Hisar", "Rohtak"
  address     String?
  phone       String?
  gstin       String?
  businessType String  @default("GENERAL")
  customLabels Json?
  isActive    Boolean  @default(true)
  remindersEnabled Boolean @default(true)
  reminderSoftDays Int     @default(7)
  reminderFollowDays Int   @default(15)
  reminderFirmDays Int     @default(30)
  subscriptionPlan SubscriptionPlan   @default(STARTER)
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  subscriptionEndsAt DateTime?
  trialStartedAt DateTime?
  trialDaysOverride Int?
  subscriptionInterval BillingInterval?
  monthlySubscriptionAmount Decimal @default(0) @db.Decimal(10, 2)
  yearlySubscriptionAmount Decimal @default(0) @db.Decimal(10, 2)
  suspendedReason String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users       User[]
  customers   Customer[]
  materials   Material[]
  orders      Order[]
  ledgerEntries LedgerEntry[]
  stockMovements StockMovement[]
  auditLogs   AuditLog[]
  paymentMethods PaymentMethod[]
  paymentTransactions PaymentTransaction[]

  @@index([isActive, subscriptionStatus])
  @@map("businesses")
}

// ─────────────────────────────────────────
// USERS — owner and munim login accounts
// ─────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  name          String
  phone         String   @unique
  role          UserRole @default(MUNIM)
  permissions   String[] @default([])
  passwordHash  String
  isActive      Boolean  @default(true)
  lastSeenAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Tenant
  business      Business? @relation(fields: [businessId], references: [id])
  businessId    String?

  // Relations
  ordersCreated    Order[]         @relation("OrderCreatedBy")
  ledgerEntries    LedgerEntry[]   @relation("LedgerRecordedBy")
  stockMovements   StockMovement[] @relation("StockRecordedBy")
  auditLogs        AuditLog[]      @relation("AuditActor")

  @@index([businessId, role, isActive])
  @@index([lastSeenAt])
  @@map("users")
}

// ─────────────────────────────────────────
// CUSTOMERS — all parties / contractors
// ─────────────────────────────────────────

model Customer {
  id           String   @id @default(uuid())
  name         String
  phone        String
  altPhone     String?
  address      String?
  siteAddress  String?
  gstin        String?
  creditLimit  Decimal  @default(0) @db.Decimal(12, 2)
  riskTag      RiskTag  @default(RELIABLE)
  notes        String?
  isActive     Boolean  @default(true)
  remindersEnabled Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Tenant
  business     Business @relation(fields: [businessId], references: [id])
  businessId   String

  // Relations
  orders         Order[]
  ledgerEntries  LedgerEntry[]
  reminders      Reminder[]

  @@index([businessId, isActive, name])
  @@index([businessId, riskTag, isActive])
  @@index([phone, businessId])
  @@map("customers")
}

// ─────────────────────────────────────────
// MATERIALS — cement, bajri, saria, crusher
// ─────────────────────────────────────────

model Material {
  id              String   @id @default(uuid())
  name            String   // e.g. "OPC Cement", "Bajri / Sand"
  unit            String   // "bags", "MT", "feet"
  stockQty        Decimal  @default(0) @db.Decimal(12, 3)
  minThreshold    Decimal  @default(0) @db.Decimal(12, 3)
  maxThreshold    Decimal? @db.Decimal(12, 3)
  purchasePrice   Decimal  @db.Decimal(10, 2)  // cost per unit
  salePrice       Decimal  @db.Decimal(10, 2)  // default sale price per unit
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Tenant
  business        Business @relation(fields: [businessId], references: [id])
  businessId      String

  // Relations
  orderItems      OrderItem[]
  stockMovements  StockMovement[]
  deliveryItems   DeliveryItem[]

  @@index([businessId, isActive, name])
  @@index([businessId, isActive, stockQty])
  @@map("materials")
}

// ─────────────────────────────────────────
// ORDERS — every sale transaction
// ─────────────────────────────────────────

model Order {
  id            String      @id @default(uuid())
  orderNumber   String      @unique  // ORD-2026-0841
  customer      Customer    @relation(fields: [customerId], references: [id])
  customerId    String
  createdBy     User        @relation("OrderCreatedBy", fields: [createdById], references: [id])
  createdById   String
  orderDate     DateTime    @default(now())
  deliveryDate  DateTime?
  status        OrderStatus @default(CONFIRMED)
  paymentMode   PaymentMode
  amountPaid    Decimal     @default(0) @db.Decimal(12, 2)
  totalAmount   Decimal     @db.Decimal(12, 2)
  marginPct     Decimal?    @db.Decimal(5, 2)  // calculated margin %
  notes         String?
  isDeleted     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Tenant
  business      Business    @relation(fields: [businessId], references: [id])
  businessId    String

  // Relations
  items          OrderItem[]
  deliveries     Delivery[]
  ledgerEntries  LedgerEntry[]
  stockMovements StockMovement[]

  @@index([businessId, isDeleted, createdAt])
  @@index([businessId, status, isDeleted, createdAt])
  @@index([businessId, customerId, isDeleted, createdAt])
  @@index([customerId, createdAt])
  @@map("orders")
}

// ─────────────────────────────────────────
// ORDER ITEMS — line items per order
// ─────────────────────────────────────────

model OrderItem {
  id             String   @id @default(uuid())
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId        String
  material       Material @relation(fields: [materialId], references: [id])
  materialId     String
  quantity       Decimal  @db.Decimal(12, 3)
  unitPrice      Decimal  @db.Decimal(10, 2)  // actual sale price charged
  purchasePrice  Decimal  @db.Decimal(10, 2)  // cost at time of order (snapshot)
  lineTotal      Decimal  @db.Decimal(12, 2)  // quantity × unitPrice

  @@index([orderId])
  @@index([materialId])
  @@map("order_items")
}

// ─────────────────────────────────────────
// LEDGER ENTRIES — digital khata
// Every debit (sale) and credit (payment) for each customer
// ─────────────────────────────────────────

model LedgerEntry {
  id           String          @id @default(uuid())
  customer     Customer        @relation(fields: [customerId], references: [id])
  customerId   String
  order        Order?          @relation(fields: [orderId], references: [id])
  orderId      String?
  type         LedgerEntryType // DEBIT or CREDIT
  amount       Decimal         @db.Decimal(12, 2)
  paymentMode  PaymentMode?
  reference    String?         // UPI txn ID, cheque number, etc.
  notes        String?
  recordedBy   User            @relation("LedgerRecordedBy", fields: [recordedById], references: [id])
  recordedById String
  createdAt    DateTime        @default(now())

  // Tenant
  business     Business        @relation(fields: [businessId], references: [id])
  businessId   String

  @@index([businessId, customerId, createdAt])
  @@index([customerId, type])
  @@index([businessId, type, createdAt])
  @@index([orderId])
  @@map("ledger_entries")
}

// ─────────────────────────────────────────
// DELIVERIES — each dispatch trip / challan
// ─────────────────────────────────────────

model Delivery {
  id                String           @id @default(uuid())
  order             Order            @relation(fields: [orderId], references: [id])
  orderId           String
  challanNumber     String           @unique  // CH-2026-0839
  driverName        String?
  vehicleNumber     String?
  status            DeliveryStatus   @default(SCHEDULED)
  confirmationType  ConfirmationType?
  confirmationRef   String?          // OTP code, photo URL, or manual note
  deliveredAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  // Relations
  items  DeliveryItem[]

  @@index([orderId, createdAt])
  @@index([status, createdAt])
  @@map("deliveries")
}

// ─────────────────────────────────────────
// DELIVERY ITEMS — actual qty delivered per material
// Separate from order items to handle disputes
// ─────────────────────────────────────────

model DeliveryItem {
  id           String   @id @default(uuid())
  delivery     Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  deliveryId   String
  material     Material @relation(fields: [materialId], references: [id])
  materialId   String
  orderedQty   Decimal  @db.Decimal(12, 3)
  deliveredQty Decimal  @db.Decimal(12, 3)

  @@index([deliveryId])
  @@index([materialId])
  @@map("delivery_items")
}

// ─────────────────────────────────────────
// STOCK MOVEMENTS — full inventory audit trail
// Auto-created on order, delivery, and manual adjustment
// ─────────────────────────────────────────

model StockMovement {
  id           String            @id @default(uuid())
  material     Material          @relation(fields: [materialId], references: [id])
  materialId   String
  order        Order?            @relation(fields: [orderId], references: [id])
  orderId      String?
  type         StockMovementType // IN, OUT, ADJUSTMENT
  quantity     Decimal           @db.Decimal(12, 3)
  stockAfter   Decimal           @db.Decimal(12, 3)  // snapshot of stock after this move
  reason       String?
  recordedBy   User              @relation("StockRecordedBy", fields: [recordedById], references: [id])
  recordedById String
  createdAt    DateTime          @default(now())

  // Tenant
  business     Business          @relation(fields: [businessId], references: [id])
  businessId   String

  @@index([businessId, materialId, createdAt])
  @@index([materialId, createdAt])
  @@index([orderId])
  @@map("stock_movements")
}

// ─────────────────────────────────────────
// REMINDERS — automated payment follow-ups
// Queued by the background job engine
// ─────────────────────────────────────────

model Reminder {
  id           String          @id @default(uuid())
  customer     Customer        @relation(fields: [customerId], references: [id])
  customerId   String
  channel      ReminderChannel @default(WHATSAPP)
  status       ReminderStatus  @default(PENDING)
  messageBody  String
  scheduledAt  DateTime
  sentAt       DateTime?
  createdAt    DateTime        @default(now())

  @@index([customerId, createdAt])
  @@index([status, createdAt])
  @@index([scheduledAt])
  @@map("reminders")
}

model AuditLog {
  id          String   @id @default(uuid())
  actor       User?    @relation("AuditActor", fields: [actorId], references: [id])
  actorId     String?
  business    Business? @relation(fields: [businessId], references: [id])
  businessId  String?
  action      String
  targetType  String
  targetId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([action, createdAt])
  @@index([businessId, createdAt])
  @@map("audit_logs")
}

model PlatformSetting {
  id                 String   @id
  trialDays          Int      @default(7)
  monthlyPrice       Decimal  @default(200) @db.Decimal(10, 2)
  yearlyPrice        Decimal  @default(2100) @db.Decimal(10, 2)
  currency           String   @default("INR")
  trialRequiresCard  Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("platform_settings")
}

model PaymentMethod {
  id                      String          @id @default(uuid())
  business                Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessId              String
  provider                PaymentProvider @default(DUMMY)
  providerCustomerId      String?
  providerPaymentMethodId String?
  cardholderName          String
  brand                   String
  last4                   String
  expMonth                Int
  expYear                 Int
  isDefault               Boolean         @default(true)
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  transactions PaymentTransaction[]

  @@index([businessId, isDefault])
  @@map("payment_methods")
}

model PaymentTransaction {
  id              String          @id @default(uuid())
  business        Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessId      String
  paymentMethod   PaymentMethod?  @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  paymentMethodId String?
  provider        PaymentProvider @default(DUMMY)
  interval        BillingInterval
  amount          Decimal         @db.Decimal(10, 2)
  currency        String          @default("INR")
  status          PaymentStatus   @default(PENDING)
  reference       String?
  failureReason   String?
  metadata        Json?
  paidAt          DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([businessId, createdAt])
  @@map("payment_transactions")
}
